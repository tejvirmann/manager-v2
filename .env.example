# ── GitHub ────────────────────────────────────────────────────────────────────
# PAT scopes: repo, read:org, project
# Create at: github.com/settings/tokens
GITHUB_PAT=ghp_your_token_here

# Repo the agent manages issues for (format: owner/repo)
GITHUB_REPO=Tejvir-PM-Stack/manager

# ── Telegram bot (optional) ───────────────────────────────────────────────────
# Create a bot via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram user ID — get it from @userinfobot (it's a number, e.g. 123456789)
TELEGRAM_ALLOWED_USER_ID=

# Model used by the Telegram bot (should be fast)
TELEGRAM_MODEL=gemma4:e4b

# ── Anthropic (optional — enables Claude Sonnet/Haiku in OpenCode) ────────────
# Get key at: console.anthropic.com
ANTHROPIC_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Paths ─────────────────────────────────────────────────────────────────────
# Set automatically by manager script — override if needed
# NOTES_INDEX_PATH=.cache/notes-index.json
